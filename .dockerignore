# --- Python artefacts ---
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# --- Test / CI artefacts ---
# NOTE: tests/ is intentionally NOT ignored — the `test` build stage copies it
# to run pytest in-container. The runtime stage never COPYs it, so the deployed
# image stays clean.
.pytest_cache/
.github/
htmlcov/
.coverage

# --- Local data (never bake the real DB into the image) ---
data/
*.db
*.sqlite
*.log
screenshots/

# --- Secrets ---
.env

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Docs (not needed at runtime) ---
doc/

# --- Infra (CDK app) — never needed in the runtime image, and its cdk.out
#     would otherwise recurse into itself during CDK asset staging ---
agent-auto-system-stack/
