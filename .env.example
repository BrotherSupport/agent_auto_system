DATABASE_URL=sqlite:///./data/auto.db

# Auth — the first admin user is seeded on startup only if no users exist yet.
# Defaults to admin / admin when unset. Change the password from the Admin page
# (or set ADMIN_PASSWORD here) before exposing the app.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# Secret used to sign session cookies. Set a long random value in production;
# rotating it logs everyone out.
APP_SECRET=dev-insecure-change-me

# LLM Providers — configure one or more
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Langfuse — LLM observability & tracing (https://langfuse.com)
# Create a project at https://cloud.langfuse.com (or self-host) and paste its
# keys below. Leave the keys blank to disable tracing entirely.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# EU cloud: https://cloud.langfuse.com  ·  US cloud: https://us.cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_ENABLED=false   # uncomment to disable even when keys are present

# Quality evaluator ("evaluate node") — the LLM-as-judge that scores each result.
# The judge is INDEPENDENT of the model that ran the job (a model grading its own
# output inflates scores). Configure it in the admin UI (Admin → Verification LLM),
# or here. Precedence: admin UI setting → these env vars → default (Gemini Flash).
# EVAL_JUDGE_PROVIDER=gemini
# EVAL_JUDGE_MODEL=gemini/gemini-2.5-flash

# Gmail (for email_sender automation)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords and generate an App Password
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Shopee seller scraper
# Credentials are used to (pre-)fill the login form. Shopee blocks fully
# headless logins with captcha/OTP, so the robust path is to run the helper
# once and reuse the saved session:
#     uv run python scripts/shopee_login.py
SHOPEE_USERNAME=your-shopee-account        # phone number or email
SHOPEE_PASSWORD=your-shopee-password
# Path to the persisted login session (cookies) the scraper reuses headlessly.
SHOPEE_STORAGE_STATE=data/shopee_state.json

# Tasker auto-apply (tasker.com.tw 自動提案)
# Credentials pre-fill the login form. tasker.com.tw is phone-based and often
# uses captcha/OTP, so the robust path is to log in once with the helper and
# reuse the saved session:
#     uv run python scripts/tasker_login.py
# Username may be a phone number or an email (email uses the /auth/legacy form).
TASKER_USERNAME=your-tasker-account        # phone number or email
TASKER_PASSWORD=your-tasker-password
# Path to the persisted login session (cookies) the automation reuses headlessly.
TASKER_STORAGE_STATE=data/tasker_state.json
